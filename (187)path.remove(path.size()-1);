/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    private void dfs(TreeNode node, int cursum, int targetsum, List<Integer> path, List<List<Integer>> result){
        if(node==null) return;
        cursum+=node.val;
        path.add(node.val);
        if(node.left==null && node.right==null && cursum==targetsum){
            result.add(new ArrayList<>(path));
        }
        dfs(node.left, cursum,targetsum, path, result);
        dfs(node.right,cursum,targetsum,path,result);
        path.remove(path.size()-1);

    }


    public List<List<Integer>> pathSum(TreeNode root, int targetSum) {
        List<List<Integer>> result = new ArrayList<>();
        dfs(root, 0, targetSum, new ArrayList<>(), result);
        return result;
    }
}
