/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    int currstrk=0;
    int maxstrk=0;
    TreeNode prev=null;
    List<Integer> result=new ArrayList<>();
    private void inorder(TreeNode node){
        if(node==null) return;
        inorder(node.left);
        if(prev!=null && prev.val==node.val){
            currstrk++;
        }
        else{
            currstrk=1;
        }
        if(currstrk>maxstrk){
            maxstrk=currstrk;
            result.clear();
            result.add(node.val);
        }
        else if(maxstrk==currstrk){
            result.add(node.val);
        }
        prev=node;
        inorder(node.right);
    }
    public int[] findMode(TreeNode root) {
        inorder(root);
        return result.stream().mapToInt(i -> i).toArray();
    }
}
