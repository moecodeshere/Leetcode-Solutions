class Solution {
    public int mySqrt(int x) {
        if(x==0) return 0;
        int l=1;
        int r=x;
        int result=0;
        while(l<=r){
            int mid =l + (r-l)/2;
            if((long)mid * mid ==x){
                return mid;
            }else if((long)mid * mid <x){
                result=mid;
                l=mid+1;
            }
            else{
                r=mid-1;
            }
        }
        return result;
    }
}
