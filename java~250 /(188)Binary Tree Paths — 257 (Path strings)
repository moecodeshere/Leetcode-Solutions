/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    private void routemaker(TreeNode node, String path,List<String> result){
        StringBuilder sb=new StringBuilder();
        if(node==null) return;
        path+=node.val;
        if(node.left==null && node.right==null){
            result.add(path);
            return;
        }
       path+="->";
        routemaker(node.left,path,result);
        routemaker(node.right,path,result);
        
        
    }
    public List<String> binaryTreePaths(TreeNode root) {
        List<String> result=new ArrayList<>();
        routemaker(root,"",result);
        return result;
    }
}
