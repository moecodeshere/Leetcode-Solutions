class Solution {
    public boolean isPerfectSquare(int num) {
        if(num==1) return true;
        long l=1;
        long r=num-1;
        while(l<=r){
            long m = l + (r-l)/2;
            long q= m*m;
            if(q==num) return true;
            else if(q < num){
                l=m+1;
            }
            else{
                r=m-1;
            }
        }
        return false;
    }
}
