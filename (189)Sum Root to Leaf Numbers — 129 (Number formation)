    private void dfs(TreeNode node,ArrayList<Integer> nums){
        if (node==null) return;
        nums.add(node.val);
        if(node.left==null && node.right==null){
            sum+=number(nums);
        
        }
        dfs(node.left,nums);
        dfs(node.right,nums);
        nums.remove(nums.size()-1);
    }




    public int sumNumbers(TreeNode root) {
        
        ArrayList<Integer> nums=new ArrayList<>();
        dfs(root,nums);
        return sum;
    }
}
