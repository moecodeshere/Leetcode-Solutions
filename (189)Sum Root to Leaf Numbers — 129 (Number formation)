/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    private int sum=0;
    private int number(ArrayList<Integer> nums){
        int zeros=1;
        int no=0;
        for(int i=nums.size()-1;i>=0;i--){
            no+=nums.get(i)*zeros;
            zeros*=10;
        }
        return no;
    }
    
